{
  "$schema": "./tokens.schema.json",
  "color": {
    "scheme": {
      "dark": {
        "primary":        "#40C6D6",
        "secondary":      "#26A69A",
        "surface":        "#13141A",
        "surfaceVariant": "#1C1E26",
        "surfaceElevated": "#262834",
        "background":     "#050507",
        "onSurface":      "#E6E8EC",
        "outline":        { "color": "#FFFFFF", "alpha": 0.12 },
        "outlineVariant": { "color": "#FFFFFF", "alpha": 0.06 }
      },
      "light": {
        "primary":        "#007C91",
        "secondary":      "#00766C",
        "surface":        "#F3F4F8",
        "surfaceVariant": "#E9EBF0",
        "surfaceElevated": "#DEE1E9",
        "background":     "#FBFBFD",
        "onSurface":      "#1C1B1F",
        "outline":        { "color": "#000000", "alpha": 0.12 },
        "outlineVariant": { "color": "#000000", "alpha": 0.06 }
      },
      "debugOverrides": {
        "dark":  { "primary": "#FF7043" },
        "light": { "primary": "#C63F17" }
      }
    },
    "semantic": {
      "dark": {
        "success": "#66BB6A",
        "warning": "#FF7043",
        "info":    "#5C6BC0",
        "progress": "#3FD9A8"
      },
      "light": {
        "success": "#388E3C",
        "warning": "#C63F17",
        "info":    "#26418F",
        "progress": "#189C76"
      }
    },
    "domain": {
      "ratingStar":  "#FFD700",
      "difficulty":  "#E53935",
      "trophyAmber": "#FFB300",
      "favoriteStar": "#FFC107",
      "achievementTier": {
        "hardcore": "#FFD700",
        "softcore": "#CD7F32"
      },
      "completion": {
        "playing":   { "dark": "#5C6BC0", "light": "#26418F" },
        "beaten":    { "dark": "#66BB6A", "light": "#388E3C" },
        "completed": { "dark": "#FFB300", "light": "#C77800" },
        "retired":   { "dark": "#9E9E9E", "light": "#757575" },
        "never":     { "dark": "#757575", "light": "#9E9E9E" }
      },
      "socialBrand": {
        "accent": "#6366F1"
      },
      "presence": {
        "online":  "#22C55E",
        "away":    "#FBBF24",
        "offline": "#6B7280"
      },
      "battery": {
        "low": "#E53935"
      },
      "code": {
        "background": { "color": "#888888", "alpha": 0.10 }
      }
    },
    "accentPresets": []
  },
  "dimension": {
    "spacing": {
      "xs":  { "base": 4,  "floor": 2 },
      "sm":  { "base": 8,  "floor": 4 },
      "md":  { "base": 16, "floor": 8 },
      "lg":  { "base": 24, "floor": 12 },
      "xl":  { "base": 32, "floor": 16 },
      "xxl": { "base": 48, "floor": 24 }
    },
    "radius": {
      "sm": 4,
      "md": 8,
      "lg": 12,
      "xl": 16,
      "panel": 6,
      "control": 8,
      "pill": 999
    },
    "border": {
      "thin":   1,
      "medium": 2,
      "thick":  2
    },
    "icon": {
      "xs": 14,
      "sm": 18,
      "md": 24,
      "lg": 32,
      "xl": 48
    },
    "dot": {
      "sm": 10,
      "lg": 14
    },
    "layout": {
      "gameCardWidth":         180,
      "gameCardHeight":        240,
      "settingsItemMinHeight": 40,
      "menuRowHeight":         40,
      "menuRowHeightLg":       52,
      "listGap":               8,
      "buttonHeight":          44,
      "buttonPaddingH":        16,
      "buttonPaddingV":        10,
      "headerHeight":          72,
      "headerHeightLg":        140,
      "footerHeight":          44,
      "modalWidth":            400,
      "modalWidthLg":          520,
      "modalWidthXl":          575
    },
    "elevation": {
      "none":    0,
      "sm":      2,
      "md":      4,
      "lg":      8,
      "focused": 16
    },
    "uiScale": {
      "min":     50,
      "max":     200,
      "default": 100,
      "step":    10
    }
  },
  "typography": {
    "displayLarge":   { "fontFamily": "SansSerif", "fontSize": 57, "lineHeight": 64, "fontWeight": 400, "letterSpacing": -0.25 },
    "displayMedium":  { "fontFamily": "SansSerif", "fontSize": 45, "lineHeight": 52, "fontWeight": 400 },
    "displaySmall":   { "fontFamily": "SansSerif", "fontSize": 36, "lineHeight": 44, "fontWeight": 400 },
    "headlineLarge":  { "fontFamily": "SansSerif", "fontSize": 32, "lineHeight": 40, "fontWeight": 600 },
    "headlineMedium": { "fontFamily": "SansSerif", "fontSize": 28, "lineHeight": 36, "fontWeight": 600 },
    "headlineSmall":  { "fontFamily": "SansSerif", "fontSize": 24, "lineHeight": 32, "fontWeight": 600 },
    "titleLarge":     { "fontFamily": "SansSerif", "fontSize": 22, "lineHeight": 28, "fontWeight": 500 },
    "titleMedium":    { "fontFamily": "SansSerif", "fontSize": 16, "lineHeight": 24, "fontWeight": 500, "letterSpacing": 0.15 },
    "titleSmall":     { "fontFamily": "SansSerif", "fontSize": 14, "lineHeight": 20, "fontWeight": 500, "letterSpacing": 0.1 },
    "bodyLarge":      { "fontFamily": "SansSerif", "fontSize": 16, "lineHeight": 24, "fontWeight": 400, "letterSpacing": 0.5 },
    "bodyMedium":     { "fontFamily": "SansSerif", "fontSize": 14, "lineHeight": 20, "fontWeight": 400, "letterSpacing": 0.25 },
    "bodySmall":      { "fontFamily": "SansSerif", "fontSize": 12, "lineHeight": 16, "fontWeight": 400, "letterSpacing": 0.4 },
    "labelLarge":     { "fontFamily": "SansSerif", "fontSize": 14, "lineHeight": 20, "fontWeight": 500, "letterSpacing": 0.1 },
    "labelMedium":    { "fontFamily": "SansSerif", "fontSize": 12, "lineHeight": 16, "fontWeight": 500, "letterSpacing": 0.5 },
    "labelSmall":     { "fontFamily": "SansSerif", "fontSize": 11, "lineHeight": 16, "fontWeight": 500, "letterSpacing": 0.5 }
  },
  "motion": {
    "spring": {
      "focus":        { "dampingRatio": 0.6,  "stiffness": 400 },
      "focusSnappy":  { "dampingRatio": 0.55, "stiffness": 700 },
      "focusReduced": { "dampingRatio": 1.0,  "stiffness": 1200 }
    },
    "tween": {
      "fast":    100,
      "medium":  500,
      "long":    1200,
      "shimmer": 2000,
      "micro":   120,
      "content": 180,
      "page":    250,
      "drawer":  450
    }
  },
  "input": {
    "debounce": {
      "transitionMs":  200,
      "focusScrollMs": 60
    },
    "scrollPaddingPercent": 0.2
  },
  "enums": {
    "ThemeMode": {
      "type": "marker",
      "values": ["LIGHT", "DARK", "SYSTEM"]
    },
    "GridDensity": {
      "type": "marker",
      "values": ["COMPACT", "NORMAL", "SPACIOUS"]
    },
    "DefaultView": {
      "type": "marker",
      "values": ["HOME", "LIBRARY"]
    },
    "DisplayRoleOverride": {
      "type": "marker",
      "values": ["AUTO", "STANDARD", "SWAPPED"]
    },
    "DualScreenInputFocus": {
      "type": "marker",
      "values": ["AUTO", "TOP", "BOTTOM"]
    },
    "BoxArtShape": {
      "type": "aspectRatio",
      "values": {
        "TALL":     [2, 3],
        "STANDARD": [3, 4],
        "SQUARE":   [1, 1]
      }
    },
    "BoxArtCornerRadius": {
      "type": "dp",
      "values": { "NONE": 0, "SMALL": 4, "MEDIUM": 8, "LARGE": 12, "EXTRA_LARGE": 16 }
    },
    "BoxArtBorderThickness": {
      "type": "dp",
      "values": { "NONE": 0, "THIN": 1, "MEDIUM": 2, "THICK": 4 }
    },
    "BoxArtBorderStyle": {
      "type": "marker",
      "values": ["SOLID", "GLASS", "GRADIENT"]
    },
    "GlassBorderTint": {
      "type": "alpha",
      "values": { "OFF": 0, "TINT_5": 0.05, "TINT_10": 0.10, "TINT_15": 0.15, "TINT_20": 0.20, "TINT_25": 0.25 }
    },
    "BoxArtGlowStrength": {
      "type": "alpha+shadow",
      "values": {
        "OFF":          { "alpha": 0,    "isShadow": false },
        "LOW":          { "alpha": 0.2,  "isShadow": false },
        "MEDIUM":       { "alpha": 0.4,  "isShadow": false },
        "HIGH":         { "alpha": 0.6,  "isShadow": false },
        "SHADOW_SMALL": { "alpha": 0.15, "isShadow": true  },
        "SHADOW_LARGE": { "alpha": 0.25, "isShadow": true  }
      }
    },
    "BoxArtOuterEffect": {
      "type": "marker",
      "values": ["OFF", "GLOW", "SHADOW", "SHINE"]
    },
    "BoxArtOuterEffectThickness": {
      "type": "px",
      "values": { "THIN": 8, "MEDIUM": 16, "THICK": 24 }
    },
    "BoxArtInnerEffect": {
      "type": "marker",
      "values": ["OFF", "GLOW", "SHADOW", "GLASS", "SHINE"]
    },
    "BoxArtInnerEffectThickness": {
      "type": "px",
      "values": { "THIN": 6, "MEDIUM": 16, "THICK": 24 }
    },
    "GlowColorMode": {
      "type": "marker",
      "values": ["AUTO", "ACCENT", "ACCENT_GRADIENT", "COVER"]
    },
    "SystemIconPosition": {
      "type": "marker",
      "values": ["OFF", "TOP_LEFT", "TOP_RIGHT"]
    },
    "SystemIconPadding": {
      "type": "dp",
      "values": { "SMALL": 4, "MEDIUM": 8, "LARGE": 12 }
    },
    "GradientPreset": {
      "type": "marker",
      "values": ["VIBRANT", "BALANCED", "SUBTLE", "CUSTOM"]
    }
  },
  "components": {
    "boxArt": {
      "shape":                "STANDARD",
      "cornerRadius":         "MEDIUM",
      "borderThickness":      "MEDIUM",
      "borderStyle":          "SOLID",
      "glassBorderTint":      "OFF",
      "glowStrength":         "MEDIUM",
      "outerEffect":          "GLOW",
      "outerEffectThickness": "THIN",
      "innerEffect":          "SHADOW",
      "innerEffectThickness": "MEDIUM",
      "glowColorMode":        "AUTO",
      "systemIconPosition":   "TOP_LEFT",
      "systemIconPadding":    "MEDIUM"
    },
    "launcher": {
      "overlayLightAlpha": 0.3,
      "overlayDarkAlpha":  0.7,
      "focusGlowAlpha":    0.4,
      "themeMode":         "SYSTEM",
      "defaultView":       "HOME",
      "gridDensity":       "NORMAL",
      "installedOnlyHome": false,
      "useAccentColorFooter": false
    },
    "focus": {
      "scaleFocused":        1.1,
      "scaleDefault":        1.0,
      "alphaFocused":        1.0,
      "alphaUnfocused":      0.85,
      "saturationFocused":   1.0,
      "saturationUnfocused": 0.3,
      "glowAlphaFocused":    0.4,
      "glowAlphaUnfocused":  0.0
    },
    "actionButton": {
      "restFillAlpha":     0.82,
      "restRimAlpha":      0.9,
      "disabledFillAlpha": 0.6
    },
    "toggle": {
      "trackWidth":  44,
      "trackHeight": 24,
      "trackRadius": 7,
      "knobWidth":   12,
      "knobHeight":  20,
      "knobRadius":  5
    },
    "trackSlider": {
      "trackHeight": 6,
      "trackRadius": 2,
      "thumbSize":   10,
      "gradientShiftRatio": 0.1
    },
    "progressBar": {
      "height":      6,
      "stripeWidth": 7,
      "stripeGap":   5,
      "gradientShiftRatio": 0.1
    },
    "downloadItem": {
      "rowHeight":  92,
      "thumbSize":  64
    },
    "modal":  { "blurRadius": 8 },
    "drawer": { "blurRadius": 24 },
    "background": {
      "blur":               40,
      "saturation":         100,
      "opacity":            100,
      "useGameBackground":  true,
      "gradientPreset":     "BALANCED",
      "gradientAdvanced":   false,
      "videoWallpaperEnabled":      false,
      "videoWallpaperDelaySeconds": 3,
      "videoWallpaperMuted":        false
    },
    "screenDimmer": {
      "enabled":      true,
      "timeoutMin":   2,
      "level":        50
    },
    "dualScreen": {
      "displayRoleOverride":  "AUTO",
      "dualScreenInputFocus": "AUTO"
    }
  }
}
