  <inceptionYear>2018</inceptionYear>
  <licenses>
    <license>
      <name>MIT License</name>
      <url>https://www.opensource.org/licenses/mit-license.php</url>
    </license>
  </licenses>
  <developers>
    <developer>
      <id>Longi</id>
      <name>Long Tran</name>
      <email>lngtrn94@gmail.com</email>
    </developer>
  </developers>
  <scm>
    <connection>scm:git:git://github.com/Longi94/JavaSteam.git</connection>
    <developerConnection>scm:git:ssh://github.com:Longi94/JavaSteam.git</developerConnection>
    <url>https://github.com/Longi94/JavaSteam/tree/master</url>
  </scm>
